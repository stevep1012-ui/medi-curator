# Firebase (클라이언트 SDK용 - 공개되어도 안전한 식별자)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxx

# Google Maps (Places API) - HTTP Referrer 제한 필수
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key

# ⚠️ Gemini API 키는 더 이상 클라이언트에 두지 않는다.
# 서버 시크릿으로 등록:  firebase functions:secrets:set GEMINI_API_KEY
# (이전 VITE_GEMINI_API_KEY 는 제거되었으며 브라우저에 노출되면 SEC-gate BLOCK.)

