{
  "name": "medi-curator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"functions/src/**/*.ts\" vite.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "scan:bundle": "node scripts/scan-bundle.mjs dist",
    "gate:static": "npm run lint && npm run build && npm run scan:secrets && npm run scan:bundle",
    "gate:release-readiness": "node scripts/check-release-readiness.mjs",
    "audit:redteam:nonlegal": "node scripts/audit-nonlegal-redteam.mjs",
    "gate:release": "npm run gate:static && npm --prefix functions run build && npm run test:coverage -- --pool=vmThreads --no-file-parallelism --maxWorkers=1 && npm run test:e2e && npm run gate:release-readiness"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/react-wrapper": "^1.2.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.15.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.8"
  }
}
