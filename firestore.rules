// Firestore Security Rules — PIPA §15/§23/§28-8 + INV-2 강제
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === 동의 기록 ===
    // 사용자 본인만 자기 동의를 읽고 새로 생성할 수 있다. update/delete 는 클라 차단.
    // 철회는 새 버전을 쓰거나, deleteDoc(자기 문서)만 허용 — DSR 서버 함수가 정공법.
    match /users/{uid}/consents/{version} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.version == version
        && request.resource.data.acceptedAt == request.time
        && request.resource.data.isAdult == true
        && request.resource.data.items.pii == true
        && request.resource.data.items.sensitiveHealth == true
        && request.resource.data.items.overseasTransfer == true
        && request.resource.data.items.location is bool;
      allow update: if false;
      // 동의 철회를 위한 자기 문서 삭제 허용. 검색 이력은 개인 디바이스 로컬 저장소에서 UI가 삭제.
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // === 회원가입 프로필 ===
    // 닉네임과 답변 받을 이메일만 저장한다. 증상/약물 등 민감 건강정보는 저장 금지.
    match /users/{uid}/profile/main {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 40
        && (request.resource.data.loginEmail == null || request.resource.data.loginEmail is string)
        && request.resource.data.answerEmail is string
        && request.resource.data.answerEmail.size() <= 254
        && request.resource.data.answerEmailSource in ['login', 'custom']
        && request.resource.data.answerEmailVerified is bool
        && request.resource.data.updatedAt == request.time
        && request.resource.data.onboardingCompletedAt == request.time;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // === 이메일 기반 프로필 별칭 ===
    // 같은 이메일을 쓰는 다른 OAuth 제공자로 로그인해도 닉네임을 복원하기 위한 최소 별칭.
    // 로그인 이메일과 일치하는 사용자만 읽고 쓸 수 있으며, 건강정보는 저장하지 않는다.
    match /memberProfilesByEmail/{emailKey} {
      allow read: if request.auth != null
        && request.auth.token.email is string
        && resource.data.loginEmail == request.auth.token.email;
      allow create, update: if request.auth != null
        && request.auth.uid == request.resource.data.sourceUid
        && request.auth.token.email is string
        && request.resource.data.loginEmail == request.auth.token.email
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 40
        && request.resource.data.answerEmail is string
        && request.resource.data.answerEmail.size() <= 254
        && request.resource.data.answerEmailSource in ['login', 'custom']
        && request.resource.data.answerEmailVerified is bool
        && request.resource.data.updatedAt == request.time;
      allow delete: if request.auth != null
        && request.auth.token.email is string
        && resource.data.loginEmail == request.auth.token.email;
    }

    // === 민감정보(증상·약물·검색이력) ===
    // 출시 1차에서는 서버 저장 금지. 검색 이력은 사용자 디바이스 로컬 저장소에만 보관.
    match /users/{uid}/symptomHistory/{docId} {
      allow read, write: if false;
    }

    // === Audit 로그 ===
    // 서버 (Admin SDK) 전용. 클라 직접 쓰기 금지.
    match /auditLogs/{docId} {
      allow read, write: if false;
    }

    // === 중앙 요청 할당량 ===
    // Cloud Functions Admin SDK 전용. 클라이언트는 조회·변경할 수 없다.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // === 기본 deny ===
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
