{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/curate", "function": { "functionId": "curate", "region": "asia-northeast3" } },
      { "source": "/api/dsr", "function": { "functionId": "dsr", "region": "asia-northeast3" } },
      { "source": "/api/pharmacies", "function": { "functionId": "pharmacies", "region": "asia-northeast3" } },
      { "source": "/api/interaction", "function": { "functionId": "interaction", "region": "asia-northeast3" } },
      { "source": "/api/pairing", "function": { "functionId": "pairing", "region": "asia-northeast3" } },
      { "source": "/api/recognize-med", "function": { "functionId": "recognizeMed", "region": "asia-northeast3" } },
      { "source": "/api/admin/usage-settings", "function": { "functionId": "adminUsageSettings", "region": "asia-northeast3" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "geolocation=(self), microphone=(self), camera=(self)" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
          { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://apis.google.com https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://*.googleapis.com https://*.gstatic.com https://maps.googleapis.com; connect-src 'self' https://*.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://generativelanguage.googleapis.com; font-src 'self' data: https://cdn.jsdelivr.net; frame-src 'self' https://mediq-kr-2026.firebaseapp.com https://apis.google.com https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "*.log"],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth":      { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "hosting":   { "port": 5000 },
    "ui":        { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
